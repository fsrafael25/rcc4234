library(tidyverse)


gastos_congresso_2020 |> 
  select(txNomeParlamentar, cpf, nuLegislatura, sgUF, sgPartido, txtDescricao,
         txtFornecedor, txtCNPJCPF, datEmissao, vlrDocumento, vlrGlosa, vlrLiquido,
